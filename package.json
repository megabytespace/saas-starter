{
  "name": "saas-starter",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply DB --remote",
    "check": "tsc --noEmit && eslint src/ && prettier --check src/",
    "fix": "eslint --fix src/ && prettier --write src/",
    "test": "playwright test",
    "test:e2e": "PROD_URL=$PROD_URL playwright test"
  },
  "dependencies": {
    "hono": "^4",
    "@hono/zod-validator": "^0.4",
    "drizzle-orm": "^0.36",
    "zod": "^3.23",
    "@clerk/backend": "^1",
    "stripe": "^17",
    "inngest": "^3",
    "resend": "^4"
  },
  "devDependencies": {
    "wrangler": "^4",
    "drizzle-kit": "^0.28",
    "eslint": "^9",
    "typescript-eslint": "^8",
    "prettier": "^3",
    "@playwright/test": "^1.49",
    "typescript": "^5.7"
  }
}
